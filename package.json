{
  "name": "brawl-claim",
  "version": "0.1.0",
  "description": "BrawlClaim checks the official Supercell Store for available Brawl Stars rewards.",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:setup": "bun scripts/auth-tool.ts",
    "build": "tsc --noEmit",
    "claim": "bun src/server.ts --claim-once",
    "deploy": "bun scripts/deploy.mjs",
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.6",
    "bun-types": "^1.3.4",
    "typescript": "^5.9.3"
  }
}
